# QEP AI Platform — Environment Variables
# Copy to .env and fill in values

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Edge function secrets (set via supabase secrets set or .secrets file)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=
# HUBSPOT_APP_ID=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=

# Node scripts (optional) — Sentry for CI / local runners (design:review, kb-eval, …)
# SENTRY_DSN=
# SENTRY_SEND_DEFAULT_PII=true
# SENTRY_ENVIRONMENT=development
