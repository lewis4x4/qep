# QEP AI Platform — Environment Variables
# Copy to .env and fill in values

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Optional — enable OpenAI realtime transcript preview in the browser.
# Requires Netlify CSP connect-src to include https://api.openai.com.
VITE_VOICE_REALTIME_ENABLED=false

# Edge function secrets (set via supabase secrets set or .secrets file)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# Optional voice model overrides. Defaults are safe for production if unset.
# OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
# OPENAI_VOICE_CAPTURE_EXTRACTION_MODEL=gpt-5.4-mini
# OPENAI_VOICE_QRM_EXTRACTION_MODEL=gpt-5.4-mini
# OPENAI_REALTIME_MODEL=gpt-realtime-2
# OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-transcribe
# SUPABASE_SERVICE_ROLE_KEY=
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=
# HUBSPOT_APP_ID=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=

# OEM Portal Credential Vault (Phase 9.1). 64-char hex (32 bytes). Distinct
# from HUBSPOT_ENCRYPTION_KEY so vault secrets have their own blast radius.
# Generate with:   openssl rand -hex 32
# Set in Supabase dashboard → Edge Functions → oem-portal-vault → Secrets.
# OEM_VAULT_ENCRYPTION_KEY=

# Node scripts (optional) — Sentry for CI / local runners (design:review, kb-eval, …)
# SENTRY_DSN=
# SENTRY_SEND_DEFAULT_PII=true
# SENTRY_ENVIRONMENT=development
