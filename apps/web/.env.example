VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
# Optional — browser errors and session replay (leave unset to disable Sentry in dev)
VITE_SENTRY_DSN=
# Optional — CI only: `vite build` uploads source maps when all three are set (see vite.config.ts)
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=
VITE_MSGRAPH_CLIENT_ID=your_azure_app_client_id_here
# IntelliDealer VitalEdge API — when set, Quote Builder is unlocked
VITE_INTELLIDEALER_URL=
