{
  "name": "@qep/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "test": "cd ../.. && bun run test",
    "test:quote-builder": "bun test --timeout=30000 src/features/quote-builder",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium",
    "test:e2e:staging": "PLAYWRIGHT_BASE_URL=https://qualityequipmentparts.netlify.app PLAYWRIGHT_SKIP_WEBSERVER=1 playwright test",
    "bundle:analyze": "ANALYZE=true bun run build",
    "bundle:check": "node ../../scripts/check-web-bundle-size.mjs",
    "lighthouse:mobile": "lhci autorun --config=.lighthouserc.cjs",
    "lighthouse:mobile:local": "LHCI_BASE_URL=http://127.0.0.1:5173 lhci autorun --config=.lighthouserc.cjs",
    "lighthouse:auth-setup": "node ./scripts/lighthouse-auth-setup.mjs",
    "lighthouse:mobile:authed": "bun run lighthouse:auth-setup && LHCI_AUTHENTICATED=true lhci autorun --config=.lighthouserc.cjs",
    "lighthouse:mobile:local:authed": "LHCI_BASE_URL=http://127.0.0.1:5173 bun run lighthouse:auth-setup && LHCI_AUTHENTICATED=true LHCI_BASE_URL=http://127.0.0.1:5173 lhci autorun --config=.lighthouserc.cjs",
    "test:raw": "bun test --timeout=30000 src"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.4.0",
    "@sentry/react": "^10.47.0",
    "@supabase/supabase-js": "^2.49.1",
    "@tanstack/react-query": "^5.90.2",
    "@types/node": "^25.5.0",
    "@types/papaparse": "^5.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.7.0",
    "maplibre-gl": "^5.22.0",
    "pako": "^2.1.0",
    "papaparse": "^5.5.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@happy-dom/global-registrator": "^20.9.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/pako": "^2.0.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.14",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.4.2"
  }
}
