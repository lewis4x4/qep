{
  "name": "qep-knowledge-assistant",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "bun run --filter @qep/web dev",
    "audit": "bun audit",
    "build": "bun run migrations:check && bun run service:cron:path-check && bun run edge:deno-check && bun run verify:service-slice && bun run --filter @qep/web build",
    "lint": "bun run --filter @qep/web lint",
    "build:web": "bun run --filter @qep/web build",
    "migrations:check": "bun ./scripts/check-migration-order.mjs",
    "demo:plan": "bun ./scripts/demo/crm-demo-data.mjs plan",
    "demo:seed": "bun ./scripts/demo/crm-demo-data.mjs seed",
    "demo:reset": "bun ./scripts/demo/crm-demo-data.mjs reset",
    "demo:reseed": "bun ./scripts/demo/crm-demo-data.mjs reseed",
    "demo:admin:seed": "bun ./scripts/demo/demo-admin.mjs seed",
    "demo:admin:reset": "bun ./scripts/demo/demo-admin.mjs reset",
    "demo:baseline:local": "QEP_DEMO_PREFER_LOCAL=1 bun ./scripts/demo/crm-demo-data.mjs baseline-local",
    "design:review": "node ./scripts/design-review-runner.js",
    "stress:test": "bun ./.agents/stress-test/run.ts",
    "segment:gates": "bun ./scripts/agent-gates/run-segment-gates.mjs",
    "supabase:start": "supabase start",
    "supabase:push": "supabase db push",
    "supabase:types": "supabase gen types typescript --local > apps/web/src/lib/database.types.ts",
    "supabase:types:remote": "sh -c 'supabase gen types typescript --project-id iciddijgonywtxoelous --schema public > apps/web/src/lib/database.types.ts && printf \"\\nexport type UserRole = Database[\\\"public\\\"][\\\"Enums\\\"][\\\"user_role\\\"]\\n\" >> apps/web/src/lib/database.types.ts'",
    "smoke:edge": "bun ./scripts/smoke-edge-functions.mjs",
    "kb:eval": "node ./scripts/kb-eval/run-eval.mjs",
    "kb:eval:report": "node ./scripts/kb-eval/eval-report.mjs",
    "kb:workspace-isolation": "node ./scripts/kb-eval/workspace-isolation.mjs",
    "pressure:parts": "bun ./scripts/parts-service-pressure/run.mjs",
    "service:cron:path-check": "bun ./scripts/service-cron-path-guard.mjs",
    "edge:deno-check": "bun ./scripts/deno-check-edge-functions.mjs",
    "demo:service-fulfillment": "bun ./scripts/demo/service-fulfillment-link-seed.mjs",
    "demo:service-parts": "bun ./scripts/demo/service-parts-seed.mjs",
    "demo:full": "bun ./scripts/demo/full-seed.mjs",
    "demo:full:local": "QEP_DEMO_PREFER_LOCAL=1 bun ./scripts/demo/full-seed.mjs baseline-local",
    "demo:verify": "bun ./scripts/demo/verify-seed.mjs",
    "verify:parts-contracts": "bun ./scripts/verify/parts-engine-contracts.mjs",
    "verify:workspace-identity": "bun ./scripts/verify/workspace-identity-contracts.mjs",
    "verify:service-cron-logging": "bun ./scripts/verify/service-cron-logging.mjs",
    "test:planner-rules": "bun test apps/web/src/features/service/lib/planner-rules.test.ts",
    "test:workspace-web": "bun test apps/web/src/hooks/useMyWorkspaceId.test.ts apps/web/src/features/parts/hooks/workspace-scoped-hooks.test.ts apps/web/src/components/WorkspaceSwitcher.test.ts",
    "test:workspace-edge": "deno test supabase/functions/_shared/workspace.test.ts",
    "test:kb-integration": "deno test supabase/functions/knowledge-base.integration.test.ts --allow-env --allow-net",
    "test:vendor-inbound-contract": "deno test supabase/functions/_shared/vendor-inbound-contract.test.ts",
    "test:vendor-escalation-resend": "deno test supabase/functions/_shared/vendor-escalation-resend.test.ts",
    "verify:service-slice": "bun run verify:parts-contracts && bun run verify:workspace-identity && bun run verify:service-cron-logging && bun run test:planner-rules && bun run test:workspace-web && bun run test:workspace-edge && bun run test:vendor-inbound-contract && bun run test:vendor-escalation-resend"
  },
  "dependencies": {
    "@sentry/node": "^10.47.0"
  }
}
