{
  "name": "qep-knowledge-assistant",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "dependencies": {
    "@supabase/supabase-js": "^2.49.1"
  },
  "scripts": {
    "dev": "bun run --filter @qep/web dev",
    "build": "bun run migrations:check && bun run floor:validate-layouts && bun run audit:rls-initplan && bun run audit:edges && bun run --filter @qep/web build",
    "build:web": "bun run --filter @qep/web build",
    "audit:rls-initplan": "node ./scripts/check-rls-initplan.mjs",
    "audit:edges": "bun ./scripts/check-edge-function-auth.mjs",
    "pressure:parts": "bun ./scripts/parts-service-pressure/run.mjs",
    "test:edge:dge": "deno test supabase/functions/_shared/market-valuation-logic.test.ts supabase/functions/_shared/dge-refresh-state.test.ts supabase/functions/_shared/dge-refresh-jobs.test.ts supabase/functions/_shared/dge-auth.test.ts",
    "dge:mixed-load": "bun ./scripts/dge/mixed-load.ts",
    "test": "bun run test:unit && bun run test:integration",
    "test:unit": "bun ./scripts/run-unit-tests.mjs",
    "test:integration": "bun ./scripts/run-integration-tests.mjs",
    "test:kb-integration": "deno test supabase/functions/knowledge-base.integration.test.ts --allow-env --allow-net --allow-read",
    "test:pricing": "bun test apps/web/src/lib/pricing apps/web/src/lib/programs",
    "migrations:check": "bun ./scripts/check-migration-order.mjs",
    "floor:validate-layouts": "bun ./scripts/floor/validate-floor-layouts.mjs",
    "floor:seed-layouts": "bun ./scripts/floor/seed-layouts-for-workspace.mjs",
    "floor:verify-production": "bun ./scripts/verify/floor-production-audit.mjs",
    "quote:status-smoke": "bun ./scripts/verify/quote-status-constraint-smoke.mjs",
    "kb:eval": "node ./scripts/kb-eval/run-eval.mjs",
    "kb:eval:report": "node ./scripts/kb-eval/eval-report.mjs",
    "kb:workspace-isolation": "node ./scripts/kb-eval/workspace-isolation.mjs",
    "db:push": "bun ./scripts/db-push.mjs",
    "db:push:apply": "bun ./scripts/db-push.mjs --apply",
    "demo:plan": "bun ./scripts/demo/crm-demo-data.mjs plan",
    "demo:seed": "bun ./scripts/demo/crm-demo-data.mjs seed",
    "demo:reset": "bun ./scripts/demo/crm-demo-data.mjs reset",
    "demo:reseed": "bun ./scripts/demo/crm-demo-data.mjs reseed",
    "demo:baseline:local": "QEP_DEMO_PREFER_LOCAL=1 bun ./scripts/demo/crm-demo-data.mjs baseline-local",
    "intellidealer:seed:purge": "bun ./scripts/purge-non-parts-seed-data.mjs",
    "design:review": "node ./scripts/design-review-runner.js",
    "stress:test": "bun ./.agents/stress-test/run.ts",
    "segment:gates": "bun ./scripts/agent-gates/run-segment-gates.mjs",
    "supabase:start": "supabase start",
    "supabase:push": "supabase db push",
    "supabase:types": "bun ./scripts/generate-supabase-types.mjs --local",
    "supabase:types:remote": "bun ./scripts/generate-supabase-types.mjs",
    "smoke:edge": "bun ./scripts/smoke-edge-functions.mjs",
    "parts:hydrate": "bun ./scripts/hydrate-parts-intelligence.ts",
    "intellidealer:customer:audit": "python3 ./scripts/audit-intellidealer-customer-master.py",
    "intellidealer:customer:stage": "python3 ./scripts/stage-intellidealer-customer-master.py",
    "intellidealer:customer:commit": "bun ./scripts/commit-intellidealer-customer-import.mjs",
    "intellidealer:customer:verify": "bun ./scripts/verify-intellidealer-customer-import.mjs",
    "intellidealer:customer:rerun-check": "bun ./scripts/verify-intellidealer-customer-rerun-safety.mjs",
    "intellidealer:customer:commit-rehearsal": "bun ./scripts/verify/intellidealer-canonical-commit-rehearsal.mjs",
    "intellidealer:production:smoke": "bun ./scripts/verify/intellidealer-production-smoke.mjs",
    "intellidealer:gap-audit:regen": "bun ./scripts/regenerate-intellidealer-gap-audit.mjs",
    "intellidealer:source:custody": "bun ./scripts/verify-intellidealer-source-custody.mjs",
    "qrm:sequences:production:smoke": "bun ./scripts/verify/qrm-follow-up-sequence-production-smoke.mjs",
    "wave5:provider:verify": "bun ./scripts/verify/wave5-deferred-provider-readiness.mjs",
    "parity:open-rows": "bun ./scripts/verify/parity-open-rows.mjs",
    "parity:workbook:verify": "bun ./scripts/verify/parity-workbook-verify.mjs",
    "parity:closeout:preflight": "bun ./scripts/verify/parity-closeout-preflight.mjs"
  },
  "devDependencies": {
    "playwright": "^1.52.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.2/xlsx-0.20.2.tgz"
  }
}
