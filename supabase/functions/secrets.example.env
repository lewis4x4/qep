# Supabase Edge Functions — template only. Set real values in Dashboard
# (Project → Edge Functions → Secrets). Do not commit filled-in files.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

SERVICE_CRON_RUNS_DISABLED=false

OPENAI_API_KEY=
# Optional voice model overrides. Defaults are safe for production if unset.
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe
OPENAI_VOICE_CAPTURE_EXTRACTION_MODEL=gpt-5.4-mini
OPENAI_VOICE_QRM_EXTRACTION_MODEL=gpt-5.4-mini
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-transcribe

RESEND_API_KEY=
RESEND_FROM=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Required for hosted Supabase; local CLI (127.0.0.1/localhost) may omit for dev.
VENDOR_INBOUND_WEBHOOK_SECRET=

ENV=production
ALLOW_VENDOR_INBOUND_OPEN_MATCH=false

PLANNER_HEURISTIC_MODE=

# demo-admin edge function (POST with header x-demo-admin-secret) — generate a strong random value
DEMO_ADMIN_SECRET=

CRON_SECRET=
